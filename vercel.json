{
  "version": 2,
  "name": "gmrit-academic-calculator",
  "builds": [
    {
      "src": "api/count.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/visitors.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/count",
      "dest": "/api/count.js"
    },
    {
      "src": "/api/visitors",
      "dest": "/api/visitors.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
